{
  "name": "cpixts",
  "version": "0.1.1",
  "description": "Isomorphic TypeScript library for CPIX (DASH-IF Content Protection Information Exchange) documents, with Widevine/PlayReady DRM and AWS SPEKE v2 support",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "author": "Ahmed Rowaihi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedrowaihi/cpixts.git"
  },
  "homepage": "https://github.com/ahmedrowaihi/cpixts#readme",
  "bugs": {
    "url": "https://github.com/ahmedrowaihi/cpixts/issues"
  },
  "keywords": [
    "cpix",
    "drm",
    "speke",
    "dash",
    "dash-if",
    "widevine",
    "playready",
    "hls",
    "pssh",
    "content-protection"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./drm": {
      "types": "./dist/drm/index.d.ts",
      "import": "./dist/drm/index.js"
    },
    "./speke": {
      "types": "./dist/speke/index.d.ts",
      "import": "./dist/speke/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "libxml2-wasm": "^0.5.0",
    "protobufjs": "^7.4.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
